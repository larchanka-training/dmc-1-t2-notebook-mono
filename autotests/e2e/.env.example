# Copy to .env (gitignored) or export in your shell before running Playwright.

# UI origin the browser visits. Local stack via nginx proxy:
BASE_URL=http://notebook.com
# Direct Vite (no proxy) alternative:
# BASE_URL=http://localhost:5173

# Backend base used for OTP login + notebook seeding (NOT proxied through the UI).
API_BASE_URL=http://localhost:8000/api/v1
