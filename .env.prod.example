# Image tag published by Docker Publish workflow.
# Use "main" for staging-like checks or immutable "sha-<short>" tags for real deployments.
IMAGE_TAG=main

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wiki

# FastAPI application
APP_NAME=JS Notebook API
APP_ENV=production
API_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000

# Internal Docker Compose database URL.
DATABASE_URL=postgresql://admin:change-me@postgres:5432/wiki

# Auth/session values.
# Replace these values before running any shared environment.
OAUTH_NAME_APPLICATION_ID=change-me
OAUTH_NAME_SECRET_KEY=change-me
TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800
