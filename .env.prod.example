# Amazon ECR registry: <account>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY=867633231218.dkr.ecr.eu-north-1.amazonaws.com

# Image tag published by the ECR Publish workflow, WITHOUT the api-/ui- prefix.
# Compose подставит префикс сам: api-${IMAGE_TAG} / ui-${IMAGE_TAG}.
# Use "latest" for staging-like checks or immutable "sha-<short>" tags for real deployments.
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wiki

# FastAPI application
APP_NAME=JS Notebook API
APP_ENV=production
API_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000

# Internal Docker Compose database URL.
DATABASE_URL=postgresql://admin:change-me@postgres:5432/wiki

# Auth/session values.
# Replace these values before running any shared environment.
OAUTH_NAME_APPLICATION_ID=change-me
OAUTH_NAME_SECRET_KEY=change-me
TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800
JWT_SECRET=change-me-at-least-32-characters
OTP_HASH_SECRET=change-me-at-least-32-characters
RESEND_API_KEY=re_xxx
EMAIL_FROM=login@example.com

# Backend code-execution endpoint (POST /api/v1/execute).
# Disabled by default: it is a debug/fallback subprocess runner, NOT a
# production sandbox (docs/execution-architecture.md §12). Keep this false in
# production unless a hardened runtime is in place. Hard guard: the API refuses
# to start if this is true in a production-like APP_ENV (no override exists).
ENABLE_EXECUTE=false
