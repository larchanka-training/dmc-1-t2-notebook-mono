# Container image registry and tag.
# IMAGE_REGISTRY: the registry host + org prefix where images are published.
#   Default: ghcr.io/larchanka-training (GHCR, the current production registry).
#   On the Beget VPS this is set in .env.prod and left as the default, so the
#   line can be omitted from .env.prod entirely once ghcr-publish.yml is the
#   source of truth.
IMAGE_REGISTRY=ghcr.io/larchanka-training

# Image tag published by the GHCR Publish workflow, WITHOUT the api-/ui- prefix.
# Compose adds the prefix: api-${IMAGE_TAG} / ui-${IMAGE_TAG}.
# Use "latest" for staging-like checks or an immutable "sha-<short>" for real deployments.
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wiki

# FastAPI application
APP_NAME=JS Notebook API
APP_ENV=production
API_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000

# Internal Docker Compose database URL.
DATABASE_URL=postgresql://admin:change-me@postgres:5432/wiki

# Auth/session values.
# Replace these values before running any shared environment.
OAUTH_NAME_APPLICATION_ID=change-me
OAUTH_NAME_SECRET_KEY=change-me
TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800
JWT_SECRET=change-me-at-least-32-characters
OTP_HASH_SECRET=change-me-at-least-32-characters
RESEND_API_KEY=re_xxx
EMAIL_FROM=login@example.com

# AWS Bedrock (LLM code generation) — the only remaining AWS dependency.
# Narrow IAM policy: bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream only.
# The server never needs any other AWS credentials.
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_DEFAULT_REGION=eu-north-1

# Backend code-execution endpoint (POST /api/v1/execute).
# Disabled by default: it is a debug/fallback subprocess runner, NOT a
# production sandbox (docs/execution-architecture.md §12). Keep this false in
# production unless a hardened runtime is in place. Hard guard: the API refuses
# to start if this is true in a production-like APP_ENV (no override exists).
ENABLE_EXECUTE=false
