# OS / Editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Environment and secrets
.env
.env.*
!.env.example
!.env.prod.example
*.local
# direnv per-project env (sets AWS_PROFILE etc.) — machine-local, never commit
.envrc

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Docker / local runtime data
.docker/
docker-data/

# TLS / cert artifacts (if generated locally)
*.pem
*.key
*.crt

# Keep submodules tracked as gitlinks
api/.git
ui/.git

# Local dev helpers (machine-specific, not for repo)
install-claude-env.sh
com.user.claude-env.plist
JS-Notebook/
summary_memory/

# Terraform (local artifacts from init/plan; state lives in the S3 backend)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
crash.log
crash.*.log
# .terraform.lock.hcl MUST be committed (the provider lock file), but locally it
# is only created on init. On a bare branch it's absent — that's fine.

# PR description drafts (produced by .agents/skills/merge-request-message)
.agents/pr-drafts/
