# OS / Editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Environment and secrets
.env
.env.*
!.env.example
!.env.prod.example
*.local
# direnv per-project env (sets AWS_PROFILE etc.) — machine-local, never commit
.envrc

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Docker / local runtime data
.docker/
docker-data/

# TLS / cert artifacts (if generated locally)
*.pem
*.key
*.crt

# Keep submodules tracked as gitlinks
api/.git
ui/.git

# Local dev helpers (machine-specific, not for repo)
install-claude-env.sh
com.user.claude-env.plist
JS-Notebook/
summary_memory/

# Terraform (локальные артефакты после init/plan; state хранится в S3-backend'е)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
crash.log
crash.*.log
# .terraform.lock.hcl ДОЛЖЕН коммититься (lock-файл провайдеров),
# но локально он создаётся только при init. На голой ветке его нет — это норм.

# PR description drafts (produced by .agents/skills/merge-request-message)
.agents/pr-drafts/
